# Canonical DNS config for external service URLs.
# Edit this file, then run: make service-dns-sync
WILDCARD_INTERNAL_HOST=*.internal.euroscale.local
INTERNAL_BASE_HOST=internal.euroscale.local
ARGOCD_HOST=argocd.internal.euroscale.local
OPENBAO_HOST=openbao.internal.euroscale.local
BACKSTAGE_HOST=backstage.internal.euroscale.local
KEYCLOAK_HOST=keycloak.internal.euroscale.local
KCP_HOST=kcp.internal.euroscale.local
ARGOCD_URL=https://argocd.internal.euroscale.local
OPENBAO_URL=https://openbao.internal.euroscale.local
BACKSTAGE_URL=https://backstage.internal.euroscale.local
KEYCLOAK_URL=https://keycloak.internal.euroscale.local
KCP_URL=https://kcp.internal.euroscale.local
COOKIE_DOMAIN=.internal.euroscale.local
ARGOCD_CALLBACK_URL=https://argocd.internal.euroscale.local/auth/callback
ARGOCD_OIDC_CLIENT_SECRET=argocd-local-secret
OPENBAO_CALLBACK_URL=https://openbao.internal.euroscale.local/oauth2/callback
BACKSTAGE_CALLBACK_URL=https://backstage.internal.euroscale.local/oauth2/callback
BASE_DOMAIN=euroscale.local
WILDCARD_BASE_HOST=*.euroscale.local
